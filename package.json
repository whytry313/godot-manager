{
  "name": "godot-manager",
  "version": "1.2.9",
  "main": "main.js",
  "homepage": "https://github.com/why-try313/godot-manager",
  "scripts": {
    "start": "NODE_ENV=dev electron .",
    "build": "cd vue && vite build && cd .. && electron-builder",
    "build-win": "cd vue && vite build && cd .. && electron-builder -w --x64",
    "buildElectron": "npm run build && electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "whytry313 <18019207+why-try313@users.noreply.github.com>",
  "license": "MIT",
  "description": "",
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "electron": "^35.1.4",
    "electron-builder": "^26.0.12",
    "vite": "^6.2.5",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "build": {
    "appId": "com.whytry313.godotmanager",
    "productName": "GodotManager",
    "artifactName": "GodotManager-${version}.${ext}",
    "directories": {
      "output": "builds"
    },
    "files": [
      "!vue",
      "./src",
      "./electrolite",
      "./main.js",
      "./server",
      {
        "from": "./dist/vue_dist",
        "to": "./public"
      }
    ],
    "linux": {
      "target": [
        "deb",
        "appImage"
      ],
      "category": "Utility",
      "icon": "public/img/logo.png"
    },
    "win": {
      "target": "portable",
      "icon": "public/img/logo.png"
    }
  },
  "electronLanguages": [
    "en_US"
  ],
  "dependencies": {
    "electrolite": "github:why-try313/electrolite",
    "node-fetch": "^2.7.0"
  }
}
